<div id="projectsContainer">

    <div id="projectsHeadingWrapper">
        <div id="projectsHeading">Projects</div>
        <a href="/portfolio/projects/addproject" id="addProjectBtn">+ Add</a>
    </div>

    <div id="projectsGrid">

        <% projects.forEach((project, index) => { %>

            <div class="projectCardWrapper">

                <!-- DELETE BUTTON -->
                 <form method="POST" action="/portfolio/projects/<%= project.projectSlug %>?_method=DELETE">
    <button type="submit" class="deleteProjectBtn" onclick="return confirm('Delete this project?')">✖</button>
</form>
                

                <a href="/portfolio/projects/<%= project.projectSlug %>" class="projectCard">

                    <!-- TOP MEDIA -->
                    <div class="projectMedia">
                        <img src="/images/project-placeholder.jpg" alt="">
                    </div>

                    <!-- BOTTOM DETAILS -->
                    <div class="projectInfo">

                        <h3><%= project.projectName %></h3>

                        <p><%= project.description %></p>

                        <div class="projectTags">
                            <% project.techStack.languages.forEach(lang => { %>
                                <span><%= lang %></span>
                            <% }) %>
                        </div>

                    </div>

                </a>

            </div>

        <% }) %>

    </div>

</div>